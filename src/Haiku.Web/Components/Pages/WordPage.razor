@page "/word/{Word}"

<PageTitle>Haiku - Poems containing "@Word"</PageTitle>

<h3 class="mb-4"><i class="fas fa-search me-2"></i>Poems containing "<em>@Word</em>"</h3>

<div class="row">
    <div class="col-lg-8">
        <div class="card haiku-card mb-3">
            <div class="card-body">
                <div class="haiku-content mb-2">
                    <p class="mb-1">The <a href="/word/@Word" class="haiku-word fw-bold">@Word</a> calls softly</p>
                    <p class="mb-1">Through the evening's gentle hush</p>
                    <p class="mb-0">Peace settles within</p>
                </div>
                <small class="text-muted">by <a href="/poet/1">poet_user</a> &middot; 2 hours ago</small>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Word { get; set; } = string.Empty;
}
