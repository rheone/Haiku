@page "/not-found"
@layout MainLayout

<PageTitle>Haiku - Not Found</PageTitle>

<div class="page-section">
    <div class="container text-center">
        <h1 class="display-1 fw-light text-muted mb-4">404</h1>
        <div class="status-poem">
            <p class="mb-3">
                I searched every word<br>
                Through pages and through pathways<br>
                You were never here
            </p>
            <p class="text-muted fst-italic">The thing you seek does not exist in this space.</p>
        </div>
        <a href="/" class="btn btn-primary mt-3">
            <i class="fas fa-home me-2"></i>Return Home
        </a>
    </div>
</div>
