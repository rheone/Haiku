@page "/admin"

<PageTitle>Haiku - Admin</PageTitle>

<h3 class="mb-4"><i class="fas fa-shield-alt me-2"></i>Admin Dashboard</h3>

<div class="row">
    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-gavel me-2"></i>Moderation</h5>
                <p class="card-text">Hide poems, disable users, and manage the community.</p>
                <button class="btn btn-outline-primary">View Actions</button>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-book me-2"></i>Dictionary</h5>
                <p class="card-text">Manage the custom dictionary and approve word suggestions.</p>
                <button class="btn btn-outline-primary">Manage Dictionary</button>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-users-cog me-2"></i>User Privileges</h5>
                <p class="card-text">Grant or revoke moderator privileges.</p>
                <button class="btn btn-outline-primary">Manage Users</button>
            </div>
        </div>
    </div>

    <div class="col-md-6 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-chart-bar me-2"></i>Statistics</h5>
                <p class="card-text">View platform statistics, logs, and errors.</p>
                <button class="btn btn-outline-primary">View Stats</button>
            </div>
        </div>
    </div>
</div>
