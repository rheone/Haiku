@page "/feed"

<PageTitle>Haiku - Feed</PageTitle>

<div class="row">
    <div class="col-lg-8">
        <h2 class="mb-4"><i class="fas fa-fire me-2"></i>Hot Feed</h2>

        <div class="mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-pen-fancy me-2"></i>Compose a Poem</h5>
                    <div class="mb-3">
                        <textarea class="form-control" rows="5"
                                  placeholder="Write your poem here...&#10;Line breaks separate each line."
                                  maxlength="500"></textarea>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge bg-secondary me-1">Type: Haiku</span>
                            <span class="badge bg-success">5</span>
                            <span class="badge bg-success">7</span>
                            <span class="badge bg-success">5</span>
                        </div>
                        <div>
                            <button class="btn btn-outline-secondary me-2" title="Generate random poem">
                                <i class="fas fa-dice"></i> Generate
                            </button>
                            <button class="btn btn-outline-primary me-2">
                                <i class="fas fa-save"></i> Save Draft
                            </button>
                            <button class="btn btn-primary">
                                <i class="fas fa-paper-plane"></i> Publish
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mb-3">
            <div class="card haiku-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <a href="/poet/1" class="text-decoration-none fw-bold">
                            <i class="fas fa-user-circle me-1"></i>poet_user
                        </a>
                        <small class="text-muted">2 hours ago</small>
                    </div>
                    <div class="haiku-content mb-3">
                        <p class="mb-1"><a href="/word/silence" class="haiku-word">Silence</a> in the <a href="/word/room" class="haiku-word">room</a></p>
                        <p class="mb-1">A <a href="/word/cicada" class="haiku-word">cicada</a>'s <a href="/word/cry" class="haiku-word">cry</a> pierces <a href="/word/through" class="haiku-word">through</a></p>
                        <p class="mb-0"><a href="/word/tranquility" class="haiku-word">Tranquility</a> found</p>
                    </div>
                    <div class="mb-2">
                        <a href="/tag/nature" class="badge bg-info text-decoration-none me-1">#nature</a>
                        <a href="/tag/peace" class="badge bg-info text-decoration-none me-1">#peace</a>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-sm btn-outline-success" title="Thumbs up">
                            <i class="fas fa-thumbs-up"></i>
                        </button>
                        <span class="fw-bold text-success">+12</span>
                        <button class="btn btn-sm btn-outline-danger" title="Thumbs down">
                            <i class="fas fa-thumbs-down"></i>
                        </button>
                        <button class="btn btn-sm btn-outline-danger" title="Love this poem">
                            <i class="fas fa-heart"></i>
                        </button>
                        <span class="text-muted small"><i class="fas fa-heart text-danger"></i> 5</span>
                        <button class="btn btn-sm btn-outline-warning ms-auto" title="Bookmark">
                            <i class="fas fa-bookmark"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-cloud me-2"></i>Word Cloud</h5>
                <div class="word-cloud">
                    <a href="/word/silence" class="badge bg-light text-dark fs-5 me-1 mb-1 text-decoration-none">silence</a>
                    <a href="/word/nature" class="badge bg-light text-dark fs-4 me-1 mb-1 text-decoration-none">nature</a>
                    <a href="/word/rain" class="badge bg-light text-dark fs-6 me-1 mb-1 text-decoration-none">rain</a>
                    <a href="/word/spring" class="badge bg-light text-dark fs-3 me-1 mb-1 text-decoration-none">spring</a>
                    <a href="/word/moon" class="badge bg-light text-dark fs-5 me-1 mb-1 text-decoration-none">moon</a>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title"><i class="fas fa-hashtag me-2"></i>Trending Tags</h5>
                <div class="d-flex flex-wrap gap-2">
                    <a href="/tag/nature" class="badge bg-primary text-decoration-none">#nature <span class="ms-1">42</span></a>
                    <a href="/tag/love" class="badge bg-primary text-decoration-none">#love <span class="ms-1">38</span></a>
                    <a href="/tag/peace" class="badge bg-primary text-decoration-none">#peace <span class="ms-1">25</span></a>
                </div>
            </div>
        </div>
    </div>
</div>
