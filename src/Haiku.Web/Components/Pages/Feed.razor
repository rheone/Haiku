@page "/feed"
@implements IAsyncDisposable
@inject IJSRuntime JS

<PageTitle>Haiku - Feed</PageTitle>

<div class="row">
    <div class="col-lg-8 feed-column mx-auto">
        <h2 class="section-title"><i class="fas fa-fire me-2"></i>Feed</h2>

        <AuthorizeView>
            <Authorized>
                <ComposeBox />
            </Authorized>
        </AuthorizeView>

        @if (Poems != null)
        {
            @foreach (var poem in Poems)
            {
                <HaikuCard PoemId="@poem.Id"
                           AuthorId="@poem.AuthorId"
                           AuthorDisplayName="@poem.AuthorName"
                           AuthorUsername="@poem.AuthorUsername"
                           Content="@poem.Content"
                           PoemTypeDisplay="@poem.TypeDisplay"
                           TotalSyllables="@poem.Syllables"
                           CreatedAt="@poem.Created"
                           ThemeKey="@poem.ThemeKey"
                           ThemeIcon="@poem.ThemeIcon"
                           ThemeDisplayName="@poem.ThemeDisplayName"
                           UpvoteCount="@poem.Upvotes"
                           DownvoteCount="@poem.Downvotes"
                           LoveCount="@poem.Loves"
                           UserVote="@poem.CurrentUserVote"
                           HasLoved="@poem.HasLoved"
                           HasBookmarked="@poem.HasBookmarked"
                           IsAuthenticated="@poem.IsAuthenticated" />
            }
        }
    </div>

    <div class="col-lg-4 sidebar-column d-none d-lg-block">
        <Sidebar WordCloudWords="@WordCloud" TrendingTags="@Trending" />
    </div>
</div>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private List<PoemDisplayModel>? Poems;
    private List<Sidebar.WordCloudEntry> WordCloud = new();
    private List<Sidebar.TrendingTagEntry> Trending = new();
    private bool IsAuth;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var state = await AuthState;
            IsAuth = state.User.Identity?.IsAuthenticated ?? false;
        }

        Poems = new List<PoemDisplayModel>
        {
            new()
            {
                Id = Guid.NewGuid(), AuthorId = Guid.NewGuid(), AuthorName = "Poet User",
                AuthorUsername = "poet_user",
                Content = "silence in the room\na cicada's cry pierces through\ntranquility found",
                TypeDisplay = "haiku", Syllables = 17, Created = DateTime.UtcNow.AddHours(-2),
                ThemeKey = "autumn", ThemeIcon = "fa-leaf", ThemeDisplayName = "Autumn",
                Upvotes = 42, Downvotes = 3, Loves = 12
            },
            new()
            {
                Id = Guid.NewGuid(), AuthorId = Guid.NewGuid(), AuthorName = "Another Poet",
                AuthorUsername = "another_poet",
                Content = "old pond—\na frog jumps in,\nsound of water",
                TypeDisplay = "haiku", Syllables = 17, Created = DateTime.UtcNow.AddHours(-5),
                ThemeKey = "summer", ThemeIcon = "fa-sun", ThemeDisplayName = "Summer",
                Upvotes = 38, Downvotes = 2, Loves = 9
            },
            new()
            {
                Id = Guid.NewGuid(), AuthorId = Guid.NewGuid(), AuthorName = "Winter Soul",
                AuthorUsername = "winter_soul",
                Content = "first winter snow\nblankets the silent garden—\na crow shakes a branch",
                TypeDisplay = "haiku", Syllables = 17, Created = DateTime.UtcNow.AddDays(-1),
                ThemeKey = "winter", ThemeIcon = "fa-snowflake", ThemeDisplayName = "Winter",
                Upvotes = 27, Downvotes = 1, Loves = 15
            }
        };

        WordCloud = new List<Sidebar.WordCloudEntry>
        {
            new() { Word = "silence", Weight = 0.9 },
            new() { Word = "nature", Weight = 0.8 },
            new() { Word = "rain", Weight = 0.6 },
            new() { Word = "spring", Weight = 0.5 },
            new() { Word = "moon", Weight = 0.7 },
            new() { Word = "wind", Weight = 0.4 },
            new() { Word = "snow", Weight = 0.6 },
            new() { Word = "water", Weight = 0.5 }
        };

        Trending = new List<Sidebar.TrendingTagEntry>
        {
            new() { Name = "nature", Count = 42 },
            new() { Name = "love", Count = 38 },
            new() { Name = "peace", Count = 25 },
            new() { Name = "winter", Count = 18 },
            new() { Name = "rain", Count = 15 },
            new() { Name = "spring", Count = 12 }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("haikuScrollDriver.init");
        }
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("haikuScrollDriver.destroy");
    }

    private class PoemDisplayModel
    {
        public Guid Id { get; set; }
        public Guid AuthorId { get; set; }
        public string AuthorName { get; set; } = string.Empty;
        public string AuthorUsername { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public string TypeDisplay { get; set; } = string.Empty;
        public int Syllables { get; set; }
        public DateTime Created { get; set; }
        public string? ThemeKey { get; set; }
        public string ThemeIcon { get; set; } = "fa-pen-nib";
        public string ThemeDisplayName { get; set; } = string.Empty;
        public int Upvotes { get; set; }
        public int Downvotes { get; set; }
        public int Loves { get; set; }
        public int CurrentUserVote { get; set; }
        public bool HasLoved { get; set; }
        public bool HasBookmarked { get; set; }
        public bool IsAuthenticated { get; set; }
    }
}
