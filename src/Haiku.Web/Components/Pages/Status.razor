@page "/status/{StatusCode:int}"
@layout MainLayout

<PageTitle>@Title - Haiku</PageTitle>

<div class="page-section">
    <div class="container text-center">
        <div class="status-code mb-4">@StatusCode</div>
        <div class="status-poem">
            @switch (StatusCode)
            {
                case 400:
                    <p class="mb-3">
                        the form sits empty<br>
                        what you asked for makes no sense<br>
                        try again, slowly
                    </p>
                    break;
                case 403:
                    <p class="mb-3">
                        this door is closed now<br>
                        no key fits the lock you hold<br>
                        another path
                    </p>
                    break;
                case 404:
                    <p class="mb-3">
                        you followed a word<br>
                        but the poem is not here<br>
                        silence fills its place
                    </p>
                    break;
                case 429:
                    <p class="mb-3">
                        too many requests<br>
                        the server needs to breathe now<br>
                        wait, then try again
                    </p>
                    break;
                case 500:
                    <p class="mb-3">
                        something broke inside<br>
                        we are looking at the break<br>
                        come back very soon
                    </p>
                    break;
                default:
                    <p class="mb-3">
                        between the transitions<br>
                        where one page becomes the next<br>
                        i have lost my way
                    </p>
                    break;
            }
        </div>
        <a href="/" class="btn btn-primary mt-3">
            <i class="fas fa-home me-2"></i>Return Home
        </a>
    </div>
</div>

@code {
    [Parameter] public int StatusCode { get; set; }

    private string Title => StatusCode switch
    {
        404 => "Not Found",
        500 => "Server Error",
        400 => "Bad Request",
        403 => "Forbidden",
        429 => "Too Many Requests",
        _ => "Status"
    };
}
