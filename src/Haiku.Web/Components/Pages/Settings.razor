@page "/settings"
@attribute [Authorize]

<PageTitle>Haiku - Settings</PageTitle>

<div class="page-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h2 class="section-title"><i class="fas fa-cog me-2"></i>Settings</h2>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-user me-2"></i>Profile</h5>
                        <div class="mb-3">
                            <label class="form-label">Display Name</label>
                            <input type="text" class="form-control" placeholder="Your display name" value="poet_user" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Bio</label>
                            <textarea class="form-control" rows="3" placeholder="A short bio...">A lover of nature and silence.</textarea>
                        </div>
                        <button class="btn btn-primary">Save Profile</button>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-palette me-2"></i>Preferences</h5>
                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="emailNotifications" checked />
                            <label class="form-check-label" for="emailNotifications">Email notifications</label>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="showNSFW" />
                            <label class="form-check-label" for="showNSFW">Show mature content</label>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-lock me-2"></i>Security</h5>
                        <div class="mb-3">
                            <label class="form-label">Current Password</label>
                            <input type="password" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">New Password</label>
                            <input type="password" class="form-control" />
                        </div>
                        <button class="btn btn-primary">Change Password</button>
                    </div>
                </div>

                <div class="card border-danger">
                    <div class="card-body">
                        <h5 class="card-title text-danger"><i class="fas fa-trash me-2"></i>Danger Zone</h5>
                        <p class="text-muted small">Once you delete your account, there is no going back.</p>
                        <button class="btn btn-outline-danger">Delete Account</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
