@page "/"

<PageTitle>Haiku - A Poetry Community</PageTitle>

<div class="hero-section">
    <h1><i class="fas fa-feather me-3"></i>Haiku</h1>
    <p>A quiet corner of the internet for seventeen syllables</p>
    <div class="mt-4">
        <a href="/feed" class="btn btn-primary me-2">
            <i class="fas fa-fire me-2"></i>Browse Poems
        </a>
        <a href="/register" class="btn btn-outline-primary">
            <i class="fas fa-user-plus me-2"></i>Join Us
        </a>
    </div>
</div>

<div class="page-section">
    <div class="container">
        <h2 class="section-title"><i class="fas fa-star me-2"></i>Top Poems</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card haiku-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/1" class="text-decoration-none fw-bold small">
                                <i class="fas fa-user-circle me-1"></i>poet_user
                            </a>
                            <span class="badge bg-warning text-dark"><i class="fas fa-crown me-1"></i>#1</span>
                        </div>
                        <div class="haiku-content mb-3 flex-grow-1">
                            <p class="mb-1">An old silent pond</p>
                            <p class="mb-1">A frog jumps into the pond</p>
                            <p class="mb-0">Splash! Silence again</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small text-muted">
                            <span><i class="fas fa-heart text-danger"></i> 24</span>
                            <span><i class="fas fa-thumbs-up"></i> 18</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card haiku-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/2" class="text-decoration-none fw-bold small">
                                <i class="fas fa-user-circle me-1"></i>another_poet
                            </a>
                            <span class="badge bg-warning text-dark"><i class="fas fa-crown me-1"></i>#2</span>
                        </div>
                        <div class="haiku-content mb-3 flex-grow-1">
                            <p class="mb-1">The falling petals</p>
                            <p class="mb-1">Dance upon the spring breeze</p>
                            <p class="mb-0">A carpet of pink</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small text-muted">
                            <span><i class="fas fa-heart text-danger"></i> 19</span>
                            <span><i class="fas fa-thumbs-up"></i> 14</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card haiku-card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/3" class="text-decoration-none fw-bold small">
                                <i class="fas fa-user-circle me-1"></i>third_poet
                            </a>
                            <span class="badge bg-warning text-dark"><i class="fas fa-crown me-1"></i>#3</span>
                        </div>
                        <div class="haiku-content mb-3 flex-grow-1">
                            <p class="mb-1">Winter morning light</p>
                            <p class="mb-1">Crystals on the window pane</p>
                            <p class="mb-0">Cold beauty remains</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small text-muted">
                            <span><i class="fas fa-heart text-danger"></i> 15</span>
                            <span><i class="fas fa-thumbs-up"></i> 11</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
