@page "/"

<PageTitle>Haiku - A Poetry Community</PageTitle>

<div class="hero-section">
    <h1><i class="fas fa-feather-alt me-3"></i>Haiku</h1>
    <p>A quiet corner of the internet for seventeen syllables</p>
    <div class="mt-4">
        <a href="/feed" class="btn btn-primary me-2">
            <i class="fas fa-fire me-2"></i>Browse Poems
        </a>
        <AuthorizeView>
            <NotAuthorized>
                <a href="/register" class="btn btn-outline-primary">
                    <i class="fas fa-user-plus me-2"></i>Join Us
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<div class="page-section">
    <div class="container">
        <h2 class="section-title"><i class="fas fa-star me-2"></i>Top Poems</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="haiku-card h-100">
                    <div class="card-tint"></div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/1" class="display-name" style="font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--color-text-primary); text-decoration: none;">
                                poet_user
                            </a>
                            <span class="badge bg-warning text-dark" style="font-family: var(--font-mono);"><i class="fas fa-crown me-1"></i>#1</span>
                        </div>
                        <div class="poem-content mb-3 flex-grow-1">
                            <p>an old silent pond</p>
                            <p>a frog jumps into the pond</p>
                            <p>splash! silence again</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small" style="color: var(--color-text-muted);">
                            <span><i class="fas fa-heart" style="color: var(--color-score-negative);"></i> 24</span>
                            <span><i class="fas fa-thumbs-up"></i> 18</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="haiku-card h-100">
                    <div class="card-tint"></div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/2" class="display-name" style="font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--color-text-primary); text-decoration: none;">
                                another_poet
                            </a>
                            <span class="badge bg-warning text-dark" style="font-family: var(--font-mono);"><i class="fas fa-crown me-1"></i>#2</span>
                        </div>
                        <div class="poem-content mb-3 flex-grow-1">
                            <p>the falling petals</p>
                            <p>dance upon the spring breeze</p>
                            <p>a carpet of pink</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small" style="color: var(--color-text-muted);">
                            <span><i class="fas fa-heart" style="color: var(--color-score-negative);"></i> 19</span>
                            <span><i class="fas fa-thumbs-up"></i> 14</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="haiku-card h-100">
                    <div class="card-tint"></div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between mb-2">
                            <a href="/poet/3" class="display-name" style="font-family: var(--font-display); font-size: 1rem; font-weight: 600; color: var(--color-text-primary); text-decoration: none;">
                                third_poet
                            </a>
                            <span class="badge bg-warning text-dark" style="font-family: var(--font-mono);"><i class="fas fa-crown me-1"></i>#3</span>
                        </div>
                        <div class="poem-content mb-3 flex-grow-1">
                            <p>winter morning light</p>
                            <p>crystals on the window pane</p>
                            <p>cold beauty remains</p>
                        </div>
                        <div class="d-flex align-items-center gap-3 small" style="color: var(--color-text-muted);">
                            <span><i class="fas fa-heart" style="color: var(--color-score-negative);"></i> 15</span>
                            <span><i class="fas fa-thumbs-up"></i> 11</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
