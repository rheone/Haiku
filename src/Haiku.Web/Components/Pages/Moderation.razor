@page "/moderation"
@attribute [Authorize]

<PageTitle>Haiku - Moderation</PageTitle>

<div class="page-section">
    <div class="container">
        <h2 class="section-title"><i class="fas fa-gavel me-2"></i>Moderation Portal</h2>
        <p class="text-muted mb-4">Review reported content and community flags.</p>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="neo-brutalist-card">
                    <div class="d-flex justify-content-between mb-2">
                        <h3><i class="fas fa-flag me-2"></i>Flagged Poems</h3>
                        <span class="badge bg-danger">3</span>
                    </div>
                    <div class="mb-2 small text-muted">
                        <p class="mb-1">"The wind whispers through..." by poet_user</p>
                        <p class="mb-1">"Autumn leaves falling..." by another_poet</p>
                        <p class="mb-0">"Silence in the room..." by third_poet</p>
                    </div>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-sm btn-outline-success">Approve All</button>
                        <button class="btn btn-sm btn-outline-danger">Hide All</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="neo-brutalist-card">
                    <div class="d-flex justify-content-between mb-2">
                        <h3><i class="fas fa-user-slash me-2"></i>Flagged Users</h3>
                        <span class="badge bg-warning text-dark">1</span>
                    </div>
                    <p class="small text-muted mb-2">spam_user — Posted 12 poems in 3 minutes.</p>
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn btn-sm btn-outline-warning">Warn</button>
                        <button class="btn btn-sm btn-outline-danger">Disable</button>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="neo-brutalist-card">
                    <div class="d-flex justify-content-between mb-2">
                        <h3><i class="fas fa-clock me-2"></i>Recent Actions</h3>
                    </div>
                    <div class="small text-muted">
                        <p class="mb-1">@* Apr 12 — Hidden poem by spam_user *@</p>
                        <p class="mb-1">Apr 11 — Warned user questionable_poet</p>
                        <p class="mb-0">Apr 10 — Approved poem #1024</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="neo-brutalist-card">
                    <div class="d-flex justify-content-between mb-2">
                        <h3><i class="fas fa-search me-2"></i>Review Queue</h3>
                        <span class="badge bg-info">5</span>
                    </div>
                    <p class="small text-muted mb-2">Poems awaiting moderator review.</p>
                    <button class="btn btn-sm btn-outline-primary w-100">Review Queue</button>
                </div>
            </div>
        </div>
    </div>
</div>
