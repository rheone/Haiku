@page "/bookmarks"
@attribute [Authorize]

<PageTitle>Haiku - Bookmarks</PageTitle>

<h3 class="mb-4"><i class="fas fa-bookmark me-2"></i>Bookmarks</h3>

<div class="alert alert-info">
    <i class="fas fa-info-circle me-2"></i>Your bookmarks are private. Only you can see them.
</div>

<div class="card haiku-card mb-3">
    <div class="card-body">
        <div class="haiku-content mb-2">
            <p class="mb-1">Cherry blossoms fall</p>
            <p class="mb-1">On the surface of the pond</p>
            <p class="mb-0">A ripple forms</p>
        </div>
        <small class="text-muted">by <a href="/poet/1">poet_user</a></small>
    </div>
</div>
