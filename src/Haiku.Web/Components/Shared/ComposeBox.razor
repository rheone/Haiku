@using Haiku.Domain.Entities
@using Haiku.Domain.Enums
@using Haiku.Domain.ValueObjects
@using Haiku.Services.Poems.Classifiers
@using Haiku.Services.Poems.Classifiers.SequenceHelpers
@inject IJSRuntime JS
@inject PoemEngine PoemEngine
@inject PoemClassifierChain ClassifierChain
@inject ThemeRecommendationService ThemeRecService
@rendermode InteractiveServer

<div class="compose-box">
    <div class="card-body">
        <div class="mb-3">
            <textarea @bind="PoemText"
                      @bind:event="oninput"
                      class="form-control"
                      rows="4"
                      placeholder="Write your poem here&#10;Line breaks separate each line"
                      maxlength="500"
                      aria-label="Poem text"></textarea>
        </div>

        @if (!string.IsNullOrWhiteSpace(PoemText))
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="type-badge">
                    @if (DetectedType.HasValue)
                    {
                        @GetTypeDisplayName(DetectedType.Value)
                    }
                </span>
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" @bind="IsFreeform" id="freeformToggle" />
                    <label class="form-check-label" for="freeformToggle" style="font-family: var(--font-ui); font-size: var(--type-ui-sm); color: var(--color-text-secondary);">Freeform</label>
                </div>
            </div>

            <div class="count-line">
                @CharCount chars · @TotalSyllables syl · @WordCount words · @LineCount lines
            </div>

            <div class="preview-panel" aria-live="polite">
                @foreach (var lineData in LineData)
                {
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="mb-0" style="flex: 1;">
                            @foreach (var word in lineData.Words)
                            {
                                <a class="word-link" href="/word/@word">@word</a>
                                <text> </text>
                            }
                        </p>
                        @if (!IsFreeform && lineData.Target > 0)
                        {
                            <span class="syllable-badge @GetBadgeClass(lineData.Syllables, lineData.Target)">
                                @lineData.Syllables / @lineData.Target
                            </span>
                        }
                        else if (IsFreeform)
                        {
                            <span class="syllable-badge progress">@lineData.Syllables</span>
                        }
                    </div>
                }
            </div>

            if (ShowRecommendation)
            {
                <div class="theme-picker-row">
                    <div class="recommendation-hint">
                        <i class="fas fa-magic me-1"></i>
                        This poem feels like <strong>@RecommendedThemeDisplayName</strong> — does that feel right?
                        <button class="btn btn-sm btn-link p-0 ms-1" @onclick="AcceptRecommendation" style="vertical-align: baseline;">Keep</button>
                        <button class="btn btn-sm btn-link p-0 ms-1 text-muted" @onclick="DismissRecommendation" style="vertical-align: baseline;">Change</button>
                    </div>
                </div>
            }
        }

        <div class="action-bar">
            <button class="btn btn-sm btn-outline-secondary" title="Generate random poem">
                <i class="fas fa-dice me-1"></i>Generate
            </button>
            <button class="btn btn-sm btn-outline-primary" title="Save as draft">
                <i class="fas fa-pencil me-1"></i>Save Draft
            </button>
            <button class="btn btn-sm btn-primary" title="Publish poem" disabled="@CanPublish">
                <i class="fas fa-paper-plane me-1"></i>Publish
            </button>
        </div>
    </div>
</div>

@code {
    private string PoemText = string.Empty;
    private bool IsFreeform;
    private PoemType? DetectedType;
    private int TotalSyllables;
    private int WordCount;
    private int LineCount;
    private int CharCount;

    private Guid? RecommendedThemeId;
    private string? RecommendedThemeDisplayName;
    private bool ShowRecommendation;

    private List<LineSyllableInfo> LineData = new();
    private bool CanPublish => string.IsNullOrWhiteSpace(PoemText);

    private class LineSyllableInfo
    {
        public string[] Words { get; set; } = [];
        public int Syllables { get; set; }
        public int Target { get; set; }
    }

    protected override void OnParametersSet()
    {
        UpdateAnalysis();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _ = Task.Run(async () =>
            {
                await Task.Delay(1200);
                if (!string.IsNullOrWhiteSpace(PoemText))
                {
                    await InvokeAsync(async () =>
                    {
                        await UpdateRecommendation();
                        StateHasChanged();
                    });
                }
            });
        }
    }

    private void UpdateAnalysis()
    {
        var text = PoemText ?? string.Empty;
        CharCount = text.Length;
        var rawLines = text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        LineCount = rawLines.Length;

        var allWords = text.Split(new[] { ' ', '\n' }, StringSplitOptions.RemoveEmptyEntries);
        WordCount = allWords.Length;

        PoemEngine.PoemAnalysis? analysis = null;
        if (!string.IsNullOrWhiteSpace(text))
        {
            try
            {
                analysis = PoemEngine.Analyze(rawLines);
                DetectedType = analysis?.DetectedType;
                TotalSyllables = analysis?.TotalSyllables ?? 0;
            }
            catch
            {
                DetectedType = IsFreeform ? PoemType.Freeform : null;
            }
        }
        else
        {
            DetectedType = null;
            TotalSyllables = 0;
        }

        var pattern = DetectedType.HasValue && !IsFreeform
            ? GetSyllablePattern(DetectedType.Value)
            : [];
        var lineAnalyses = analysis?.Lines ?? [];

        LineData = rawLines.Select((line, i) =>
        {
            var words = line.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            var syl = i < lineAnalyses.Count ? lineAnalyses[i].TotalSyllables : 0;
            if (syl == 0 && words.Length > 0)
            {
                try
                {
                    var lineDef = PoemEngine.Analyze(line);
                    syl = lineDef.TotalSyllables;
                }
                catch { }
            }
            return new LineSyllableInfo
            {
                Words = words,
                Syllables = syl,
                Target = i < pattern.Length ? pattern[i] : 0
            };
        }).ToList();
    }

    private async Task UpdateRecommendation()
    {
        if (string.IsNullOrWhiteSpace(PoemText)) return;
        try
        {
            var result = await ThemeRecService.RecommendAsync(PoemText);
            if (result.ThemeId != null && result.Confidence >= 0.55)
            {
                RecommendedThemeId = result.ThemeId;
                RecommendedThemeDisplayName = result.ThemeDisplayName;
                ShowRecommendation = true;
            }
        }
        catch { }
    }

    private void AcceptRecommendation()
    {
        ShowRecommendation = false;
    }

    private void DismissRecommendation()
    {
        ShowRecommendation = false;
        RecommendedThemeId = null;
    }

    private static string GetBadgeClass(int actual, int target)
    {
        if (target == 0) return "progress";
        if (actual > target) return "over";
        if (actual == target) return "ok";
        return "progress";
    }

    private int[] GetSyllablePattern(PoemType type)
    {
        var classifier = ClassifierChain.GetType(type);
        return classifier is not null ? ClassifierBuilder.GetInfo(classifier).SyllablePattern ?? [] : [];
    }

    private string GetTypeDisplayName(PoemType type)
    {
        var classifier = ClassifierChain.GetType(type);
        return classifier is not null ? ClassifierBuilder.GetInfo(classifier).DisplayName : "freeform";
    }
}
