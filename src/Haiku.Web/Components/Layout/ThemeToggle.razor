@rendermode InteractiveServer
@inject IJSRuntime JS

<button class="btn btn-sm nav-link border-0" @onclick="ToggleTheme" title="Toggle theme">
    <i class="fas @(_currentTheme == "dark" ? "fa-sun" : "fa-moon")"></i>
</button>

@code {
    private string _currentTheme = "light";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _currentTheme = await JS.InvokeAsync<string>("haikuTheme.getTheme");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        _currentTheme = _currentTheme == "light" ? "dark" : "light";
        await JS.InvokeVoidAsync("haikuTheme.setTheme", _currentTheme);
    }
}
