# Force LF line endings for files that must run on Linux
*.bash          text eol=lf
*.editorconfig  text eol=lf
*.sh            text eol=lf

# Other text files — normalize to LF
*.json          text eol=lf
*.jsonc         text eol=lf
*.md            text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
Dockerfile      text eol=lf

# Windows-only files — keep CRLF
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.cs            text eol=crlf
*.ps1           text eol=crlf