# Auto-normalize line endings
* text=auto

# C# source
*.cs text diff=csharp

# Solution files (binary merge to avoid corruption)
*.sln    merge=binary
*.slnx   merge=binary
*.csproj merge=binary
*.props  merge=binary
*.targets merge=binary

# Build and config
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.config text eol=lf
*.editorconfig text eol=lf

# Scripts
*.sh text eol=lf
*.ps1 text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Documentation
*.md text diff=markdown
*.txt text

# Binary files (never normalize)
*.png binary
*.jpg binary
*.ico binary
*.pfx binary
*.snupkg binary
*.nupkg binary
