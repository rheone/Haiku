# Environment variables for Haiku local Docker deployment.
# Copy this file to .env and adjust values as needed.

# SQL Server SA password (min 8 chars with uppercase, lowercase, and digit/special)
SA_PASSWORD=Haiku@Dev2024!

# Port mappings
DB_PORT=1433
WEB_PORT=5000

# ASP.NET environment (Debug, Development, Dev, Qual, Production)
ASPNETCORE_ENVIRONMENT=Development

# Build configuration (Debug, Dev, Qual, Release)
BUILD_CONFIG=Release
