### VisualStudioCode ###
.vscode/*
!.vscode/tasks.json
.history

# Environment overrides
.env

# User-specific files (MonoDevelop/Xamarin Studio)
*.rsuser
mono_crash.*

# Build output variants
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# Visual Studio 2017 auto generated files
Generated\ Files/

# Benchmark results
BenchmarkDotNet.Artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_h.h
*.iobj
*.ipdb
*_wpftmp.csproj

# NuGet Packages
*.nupkg
**/[Pp]ackages/*
!**/packages/build/
*.nuget.props
*.nuget.targets

# .NET assemblies
*.dll

# Windows thumbnail cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Windows Installer
*.cab
*.msi
*.msix
*.msm

# Windows shortcuts
*.lnk

# Coderush
**/.cr/*

# Documentation build output
docs/_build

# Smoke test local NuGet feed
Arcus.SmokeTests/feed/

# Benchmark results (commit manually with git add -f)
src/results/

# Planning and working documents
RELEASE-*.md
future.todo.md
skills-lock.json

# Build manifest/SBOM
_manifest/

# Agent/IDE config directories (keep local, don't track)
.claude/
.opencode/

# Test results
TestResults/

# NuGet lock files (committed for audit trail)
# packages.lock.json — tracked via 'git add -f'
